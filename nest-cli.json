{
  "$schema": "https://json.schemastore.org/nest-cli",
  "collection": "@nestjs/schematics",
  "sourceRoot": "src",
  "compilerOptions": {
    "deleteOutDir": true,
    "watchAssets": true,
    "assets": [
      {
        "include": "scrape/views/**/*.html",
        "outDir": "dist/src",
        "watchAssets": true
      }
    ]
  }
}
