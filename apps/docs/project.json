{
    "name": "docs",
    "$schema": "../../node_modules/nx/schemas/project-schema.json",
    "sourceRoot": "apps/docs/src",
    "projectType": "application",
    "tags": [
        "type:app",
        "scope:docs"
    ],
    "targets": {
        "build": {
            "executor": "nx:run-commands",
            "outputs": [
                "{workspaceRoot}/apps/docs/dist"
            ],
            "options": {
                "command": "pnpm astro build",
                "cwd": "apps/docs"
            }
        },
        "serve": {
            "executor": "nx:run-commands",
            "options": {
                "command": "pnpm astro dev",
                "cwd": "apps/docs"
            }
        },
        "preview": {
            "executor": "nx:run-commands",
            "options": {
                "command": "pnpm astro preview",
                "cwd": "apps/docs"
            }
        },
        "lint": {
            "executor": "nx:run-commands",
            "options": {
                "command": "pnpm astro check",
                "cwd": "apps/docs"
            }
        }
    }
}