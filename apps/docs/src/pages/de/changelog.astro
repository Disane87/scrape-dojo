---
import StarlightPage from '@astrojs/starlight/components/StarlightPage.astro';
import Changelog from '../../components/Changelog.astro';
import { parseChangelog, changelogToHeadings } from '../../utils/changelog';

const changelog = parseChangelog();
const headings = changelogToHeadings(changelog);
---

<StarlightPage
  frontmatter={{
    title: 'Changelog',
    description: 'Alle Aenderungen und Releases von Scrape Dojo',
  }}
  headings={headings}
>
  <p>Alle veroeffentlichten Versionen von Scrape Dojo mit ihren Aenderungen.</p>
  <Changelog />
</StarlightPage>
