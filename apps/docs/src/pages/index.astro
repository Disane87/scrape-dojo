<!-- Changelog Modal -->
<div class="changelog-overlay" id="changelog-overlay">
    <div class="changelog-modal">
        <div class="changelog-header">
            <h2>
                <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z"/><polyline points="14 2 14 8 20 8"/><line x1="16" y1="13" x2="8" y2="13"/><line x1="16" y1="17" x2="8" y2="17"/><polyline points="10 9 9 9 8 9"/></svg>
                Changelog <span>v{version}</span>
            </h2>
            <button class="changelog-close" id="changelog-close">
                <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><line x1="18" y1="6" x2="6" y2="18"/><line x1="6" y1="6" x2="18" y2="18"/></svg>
            </button>
        </div>
        <div class="changelog-body">
            {changelog.length === 0 && (
                <p style="color: var(--text-muted); font-size: 0.875rem;">No changelog entries found.</p>
            )}
            {changelog.map((entry) => (
                <div class="changelog-entry">
                    <div class="changelog-entry-header">
                        <span class="changelog-entry-version">v{entry.version}</span>
                        <span class="changelog-entry-date">{entry.date}</span>
                    </div>
                    {entry.sections.map((section) => (
                        <div>
                            <div class="changelog-section-title">
                                <span>{section.emoji}</span>
                                {section.title}
                            </div>
                            <ul class="changelog-items">
                                {section.items.map((item) => <li>{item}</li>)}
                            </ul>
                        </div>
                    ))}
                </div>
            ))}
        </div>
    </div>
</div>

<script>
// ---- Changelog modal ----
const changelogTrigger = document.getElementById('changelog-trigger');
const changelogOverlay = document.getElementById('changelog-overlay');
const changelogClose = document.getElementById('changelog-close');

changelogTrigger?.addEventListener('click', () => changelogOverlay?.classList.add('open'));
changelogClose?.addEventListener('click', () => changelogOverlay?.classList.remove('open'));
changelogOverlay?.addEventListener('click', (e) => {
    if (e.target === changelogOverlay) changelogOverlay.classList.remove('open');
});
document.addEventListener('keydown', (e) => {
    if (e.key === 'Escape') changelogOverlay?.classList.remove('open');
});

// ---- Scroll reveal with IntersectionObserver ----
const observer = new IntersectionObserver((entries) => {
    entries.forEach(entry => {
        if (entry.isIntersecting) {
            entry.target.classList.add('visible');

            // Counter animation for stats
            const val = entry.target.querySelector('.stat-value');
            if (val) {
                const target = val.dataset.target;
                const suffix = val.dataset.suffix || '';
                const text = val.dataset.text;
                if (text) {
                    animateText(val, text);
                } else if (target) {
                    animateCounter(val, parseInt(target), suffix);
                }
            }

            // Steps line animation
            if (entry.target.id === 'steps-line') {
                entry.target.classList.add('visible');
            }
        }
    });
}, { threshold: 0.15, rootMargin: '0px 0px -60px 0px' });

document.querySelectorAll('.reveal, .reveal-scale, .reveal-left, #steps-line').forEach(el => observer.observe(el));

// ---- Counter animation ----
function animateCounter(el, target, suffix) {
    let current = 0;
    const duration = 1200;
    const step = target / (duration / 16);
    const timer = setInterval(() => {
        current += step;
        if (current >= target) {
            current = target;
            clearInterval(timer);
        }
        el.textContent = Math.floor(current) + suffix;
    }, 16);
}
function animateText(el, text) {
    el.textContent = '';
    let i = 0;
    const timer = setInterval(() => {
        el.textContent += text[i];
        i++;
        if (i >= text.length) clearInterval(timer);
    }, 120);
}

// ---- Nav scroll effect ----
let ticking = false;
window.addEventListener('scroll', () => {
    if (!ticking) {
        requestAnimationFrame(() => {
            document.getElementById('nav').classList.toggle('scrolled', window.scrollY > 50);
            ticking = false;
        });
        ticking = true;
    }
});

// ---- Feature card cursor glow ----
document.querySelectorAll('.feature-card').forEach(card => {
    card.addEventListener('mousemove', e => {
        const rect = card.getBoundingClientRect();
        card.style.setProperty('--mx', ((e.clientX - rect.left) / rect.width * 100) + '%');
        card.style.setProperty('--my', ((e.clientY - rect.top) / rect.height * 100) + '%');
    });
});

// ---- Code typing animation ----
const codeLines = [
    ['brace', '{'],
    ['key-str', '  "scrapes": [{'],
    ['key-str', '    "id": "invoice-download",'],
    ['key-str', '    "metadata": {'],
    ['key-str', '      "description": "Download invoices monthly",'],
    ['key-str', '      "triggers": [{ "type": "cron" }]'],
    ['brace', '    },'],
    ['key-str', '    "steps": [{'],
    ['key-str', '      "name": "Login & Download",'],
    ['key-str', '      "actions": ['],
    ['action', '        { "action": "navigate",'],
    ['params', '          "params": { "url": "https://portal.example.com" } },'],
    ['action', '        { "action": "type",'],
    ['params', '          "params": { "selector": "#email",'],
    ['tmpl',   '            "text": "{{variables.email}}" } },'],
    ['action', '        { "action": "click",'],
    ['params', '          "params": { "selector": "button[type=submit]" } },'],
    ['action', '        { "action": "download",'],
    ['params', '          "params": { "url": "{{previousData.pdfUrl}}",'],
    ['params', '            "path": "./invoices" } }'],
    ['brace', '      ]'],
    ['brace', '    }]'],
    ['brace', '  }]'],
    ['brace', '}'],
];

function colorize(type, text) {
    return text
        .replace(/\{\{[^}]+\}\}/g, m => `__TMPL_${m}__`)
        .replace(/"([^"]*)"(\s*:)/g, '<span class="key">"$1"</span>$2')
        .replace(/:\s*"([^"]*)"/g, ': <span class="str">"$1"</span>')
        .replace(/\b(\d+(\.\d+)?)\b/g, '<span class="num">$1</span>')
        .replace(/\b(true|false)\b/g, '<span class="bool">$1</span>')
        .replace(/\bnull\b/g, '<span class="null">null</span>')
        .replace(/__TMPL_(\{\{[^}]+\}\})__/g, '<span class="tmpl">$1</span>')
        .replace(/([{}])/g, '<span class="brace">$1</span>')
        .replace(/([\[\]])/g, '<span class="bracket">$1</span>');
}

const codeBlock = document.getElementById('hero-code-block');
let lineIdx = 0;
function typeLine() {
    if (lineIdx >= codeLines.length) return;
    const [type, text] = codeLines[lineIdx];
    const span = document.createElement('span');
    span.className = 'code-line';
    span.style.opacity = '0';
    span.style.transform = 'translateY(8px)';
    span.innerHTML = colorize(type, text) + '\n';
    codeBlock.appendChild(span);

    requestAnimationFrame(() => {
        span.style.transition = 'opacity 0.3s, transform 0.3s';
        span.style.opacity = '1';
        span.style.transform = 'translateY(0)';
    });

    lineIdx++;
    setTimeout(typeLine, 55 + Math.random() * 30);
}
// Start typing after a short delay
setTimeout(typeLine, 800);
</script>

</body>
