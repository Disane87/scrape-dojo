---
import fs from 'node:fs';
import path from 'node:path';

const title = 'Scrape Dojo';
const description = 'Define your scrapes with JSON configurations, use dynamic templates, and automate web tasks.';
const year = new Date().getFullYear();

// Read version from root package.json (not docs/package.json)
const rootPkgPaths = [
  path.resolve(process.cwd(), '..', '..', 'package.json'), // from apps/docs/
  path.resolve(process.cwd(), 'package.json'),              // fallback
];
let version = 'unknown';
for (const p of rootPkgPaths) {
  if (fs.existsSync(p)) {
    const pkg = JSON.parse(fs.readFileSync(p, 'utf-8'));
    if (pkg.version && pkg.version !== '0.0.1') {
      version = pkg.version;
      break;
    }
  }
}

// Read and parse CHANGELOG.md
interface ChangelogSection {
  emoji: string;
  title: string;
  items: string[];
}

interface ChangelogEntry {
  version: string;
  date: string;
  sections: ChangelogSection[];
}

// Map of known section headings to their emoji + display name
const sectionMap: Record<string, { emoji: string; title: string }> = {
  'features': { emoji: '🚀', title: 'Features' },
  'fixes': { emoji: '🛠️', title: 'Fixes' },
  'bug fixes': { emoji: '🛠️', title: 'Fixes' },
  'performance': { emoji: '⚡', title: 'Performance' },
  'reverts': { emoji: '🔙', title: 'Reverts' },
  'docs': { emoji: '📔', title: 'Docs' },
  'styles': { emoji: '💎', title: 'Styles' },
  'refactor': { emoji: '♻️', title: 'Refactor' },
  'tests': { emoji: '🧪', title: 'Tests' },
  'build': { emoji: '📦', title: 'Build' },
  'ci': { emoji: '🤖', title: 'CI' },
  'chore': { emoji: '🔧', title: 'Chore' },
  'breaking changes': { emoji: '⚠', title: 'Breaking Changes' },
};

function parseChangelog(): ChangelogEntry[] {
  const possiblePaths = [
    path.resolve(process.cwd(), 'CHANGELOG.md'),
    path.resolve(process.cwd(), '..', '..', 'CHANGELOG.md'),
  ];

  let markdown = '';
  for (const p of possiblePaths) {
    if (fs.existsSync(p)) {
      markdown = fs.readFileSync(p, 'utf-8');
      break;
    }
  }

  if (!markdown) return [];

  const entries: ChangelogEntry[] = [];
  const versionRegex = /^## \[?(\d+\.\d+\.\d+)\]?(?:\([^)]*\))?\s*\((\d{4}-\d{2}-\d{2})\)/gm;

  const matches: { version: string; date: string; index: number }[] = [];
  let match;
  while ((match = versionRegex.exec(markdown)) !== null) {
    matches.push({ version: match[1], date: match[2], index: match.index });
  }

  for (let i = 0; i < matches.length; i++) {
    const start = matches[i].index;
    const end = i + 1 < matches.length ? matches[i + 1].index : markdown.length;
    const section = markdown.substring(start, end);

    const sections = extractSections(section);

    if (sections.length > 0) {
      entries.push({ version: matches[i].version, date: matches[i].date, sections });
    }
  }

  return entries;
}

function extractSections(versionBlock: string): ChangelogSection[] {
  const sections: ChangelogSection[] = [];
  // Match ### headings with optional emoji prefix, e.g. "### 🚀 Features" or "### Bug Fixes"
  const headingRegex = /^### (?:[^\w]*\s*)?(.+)$/gm;
  const headingMatches: { title: string; index: number }[] = [];
  let hm;
  while ((hm = headingRegex.exec(versionBlock)) !== null) {
    headingMatches.push({ title: hm[1].trim(), index: hm.index });
  }

  for (let j = 0; j < headingMatches.length; j++) {
    const start = headingMatches[j].index;
    const end = j + 1 < headingMatches.length ? headingMatches[j + 1].index : versionBlock.length;
    const block = versionBlock.substring(start, end);

    const items = block
      .split('\n')
      .filter((line: string) => line.trim().startsWith('*') || line.trim().startsWith('-'))
      .map((line: string) =>
        line.trim()
          .replace(/^[-*]\s*/, '')
          .replace(/\*\*([^*]+)\*\*/g, '$1')
          .replace(/\([a-f0-9]{7}\)/g, '')
          .replace(/\[([a-f0-9]{7,})\]\([^)]+\)/g, '')
          .replace(/,?\s*closes?\s*\[#\d+\]\([^)]+\)/gi, '')
          .trim()
      )
      .filter((item: string) => item.length > 0);

    if (items.length === 0) continue;

    // Strip emoji from raw title to look up in sectionMap
    const rawTitle = headingMatches[j].title;
    const titleNoEmoji = rawTitle.replace(/^[^\w]*/u, '').trim();
    const key = titleNoEmoji.toLowerCase();
    const mapped = sectionMap[key];

    sections.push({
      emoji: mapped?.emoji || '📋',
      title: mapped?.title || titleNoEmoji,
      items,
    });
  }

  return sections;
}

const changelog = parseChangelog();
---

<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>{title} -- Declarative Web Scraping Framework</title>
    <meta name="description" content={description} />
    <link rel="icon" type="image/png" href="/scrape-dojo-app-icon-64x64.png" />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;800;900&family=JetBrains+Mono:wght@400;500&display=swap" rel="stylesheet" />

    <style>
        :root {
            --bg: #050507;
            --bg-subtle: #0f0f12;
            --surface: #141418;
            --surface-2: #1c1c22;
            --border: #2a2a32;
            --border-muted: #1e1e26;
            --text: #f0f0f3;
            --text-muted: #9898a6;
            --text-subtle: #6b6b78;
            --accent: #f97316;
            --accent-hover: #fb923c;
            --green: #22c55e;
            --blue: #3b82f6;
            --purple: #a855f7;
            --red: #ef4444;
            --yellow: #eab308;
            --cyan: #06b6d4;
        }

        * { margin: 0; padding: 0; box-sizing: border-box; }
        html { scroll-behavior: smooth; }

        body {
            font-family: 'Inter', system-ui, sans-serif;
            background: var(--bg);
            color: var(--text);
            line-height: 1.6;
            overflow-x: hidden;
        }

        .container { max-width: 1200px; margin: 0 auto; padding: 0 2rem; }

        /* =========== ANIMATIONS =========== */
        @keyframes fadeUp {
            from { opacity: 0; transform: translateY(40px); }
            to { opacity: 1; transform: translateY(0); }
        }
        @keyframes fadeIn {
            from { opacity: 0; }
            to { opacity: 1; }
        }
        @keyframes scaleIn {
            from { opacity: 0; transform: scale(0.9); }
            to { opacity: 1; transform: scale(1); }
        }
        @keyframes slideLeft {
            from { opacity: 0; transform: translateX(60px); }
            to { opacity: 1; transform: translateX(0); }
        }
        @keyframes float {
            0%, 100% { transform: translateY(0); }
            50% { transform: translateY(-20px); }
        }
        @keyframes pulse-glow {
            0%, 100% { opacity: 0.4; }
            50% { opacity: 0.8; }
        }
        @keyframes shimmer {
            0%, 100% { background-position: 0% center; }
            50% { background-position: 200% center; }
        }
        @keyframes gradient-shift {
            0% { background-position: 0% 50%; }
            50% { background-position: 100% 50%; }
            100% { background-position: 0% 50%; }
        }
        @keyframes orbit {
            from { transform: rotate(0deg) translateX(300px) rotate(0deg); }
            to { transform: rotate(360deg) translateX(300px) rotate(-360deg); }
        }
        @keyframes type-cursor {
            0%, 100% { border-color: var(--accent); }
            50% { border-color: transparent; }
        }
        @keyframes draw-line {
            from { width: 0; }
            to { width: 100%; }
        }
        @keyframes counter-pulse {
            0% { transform: scale(1); }
            50% { transform: scale(1.05); }
            100% { transform: scale(1); }
        }

        /* Reveal system */
        .reveal {
            opacity: 0;
            transform: translateY(40px);
            transition: opacity 0.8s cubic-bezier(0.16, 1, 0.3, 1),
                        transform 0.8s cubic-bezier(0.16, 1, 0.3, 1);
        }
        .reveal.visible {
            opacity: 1;
            transform: translateY(0);
        }
        .reveal-scale {
            opacity: 0;
            transform: scale(0.92);
            transition: opacity 0.8s cubic-bezier(0.16, 1, 0.3, 1),
                        transform 0.8s cubic-bezier(0.16, 1, 0.3, 1);
        }
        .reveal-scale.visible {
            opacity: 1;
            transform: scale(1);
        }
        .reveal-left {
            opacity: 0;
            transform: translateX(60px);
            transition: opacity 0.8s cubic-bezier(0.16, 1, 0.3, 1),
                        transform 0.8s cubic-bezier(0.16, 1, 0.3, 1);
        }
        .reveal-left.visible {
            opacity: 1;
            transform: translateX(0);
        }
        /* Stagger children */
        .stagger > * { transition-delay: calc(var(--i, 0) * 0.1s); }

        /* =========== NAV =========== */
        nav {
            position: fixed; top: 0; left: 0; right: 0; z-index: 100;
            padding: 1.25rem 0;
            background: rgba(5, 5, 7, 0.6);
            backdrop-filter: blur(20px);
            border-bottom: 1px solid transparent;
            transition: all 0.4s ease;
        }
        nav.scrolled {
            padding: 0.75rem 0;
            background: rgba(5, 5, 7, 0.9);
            border-bottom-color: var(--border-muted);
        }
        nav .container { display: flex; align-items: center; justify-content: space-between; }
        .nav-brand {
            display: flex; align-items: center; gap: 0.75rem;
            text-decoration: none; color: var(--text);
            font-weight: 800; font-size: 1.125rem;
            letter-spacing: -0.02em;
        }
        .nav-brand img { height: 28px; width: 28px; transition: transform 0.3s; }
        .nav-brand:hover img { transform: rotate(12deg) scale(1.1); }
        .nav-links { display: flex; align-items: center; gap: 2rem; }
        .nav-links a {
            color: var(--text-muted); text-decoration: none;
            font-size: 0.875rem; font-weight: 500;
            transition: color 0.3s;
            position: relative;
        }
        .nav-links a:not(.nav-cta)::after {
            content: '';
            position: absolute; bottom: -4px; left: 0;
            width: 0; height: 1.5px;
            background: var(--accent);
            transition: width 0.3s;
        }
        .nav-links a:not(.nav-cta):hover { color: var(--text); }
        .nav-links a:not(.nav-cta):hover::after { width: 100%; }
        .nav-cta {
            padding: 0.5rem 1.25rem !important;
            background: var(--accent) !important;
            color: white !important;
            border-radius: 8px;
            font-weight: 600 !important;
            transition: all 0.3s !important;
            box-shadow: 0 0 20px rgba(249,115,22,0.2);
        }
        .nav-cta:hover {
            background: var(--accent-hover) !important;
            transform: translateY(-1px) !important;
            box-shadow: 0 4px 24px rgba(249,115,22,0.4) !important;
        }

        /* Version badge */
        .nav-version {
            display: inline-flex; align-items: center; gap: 0.4rem;
            padding: 0.25rem 0.75rem;
            background: rgba(249,115,22,0.1);
            border: 1px solid rgba(249,115,22,0.25);
            border-radius: 20px;
            font-size: 0.75rem; font-weight: 600;
            color: var(--accent);
            cursor: pointer;
            transition: all 0.3s;
            text-decoration: none;
        }
        .nav-version:hover {
            background: rgba(249,115,22,0.2);
            border-color: rgba(249,115,22,0.5);
            color: var(--accent-hover);
        }
        .nav-version svg { width: 12px; height: 12px; }

        .nav-sponsor {
            display: inline-flex; align-items: center; gap: 0.4rem;
            padding: 0.25rem 0.75rem;
            background: rgba(219,39,119,0.1);
            border: 1px solid rgba(219,39,119,0.25);
            border-radius: 20px;
            font-size: 0.75rem; font-weight: 600;
            color: #db2777;
            transition: all 0.3s;
            text-decoration: none !important;
        }
        .nav-sponsor::after { display: none !important; }
        .nav-sponsor:hover {
            background: rgba(219,39,119,0.2);
            border-color: rgba(219,39,119,0.5);
            color: #be185d;
        }
        .nav-sponsor svg { width: 14px; height: 14px; }

        .btn-sponsor:hover { border-color: #db2777; color: #db2777; }

        /* Changelog Modal */
        .changelog-overlay {
            position: fixed; inset: 0;
            background: rgba(0,0,0,0.7);
            backdrop-filter: blur(8px);
            z-index: 1000;
            display: none; align-items: center; justify-content: center;
            padding: 2rem;
            animation: fadeIn 0.2s ease;
        }
        .changelog-overlay.open { display: flex; }
        .changelog-modal {
            background: var(--surface);
            border: 1px solid var(--border);
            border-radius: 16px;
            width: 100%; max-width: 640px;
            max-height: 80vh;
            display: flex; flex-direction: column;
            animation: scaleIn 0.25s ease;
            box-shadow: 0 24px 64px rgba(0,0,0,0.5);
        }
        .changelog-header {
            display: flex; align-items: center; justify-content: space-between;
            padding: 1.25rem 1.5rem;
            border-bottom: 1px solid var(--border);
        }
        .changelog-header h2 {
            font-size: 1.125rem; font-weight: 700;
            display: flex; align-items: center; gap: 0.5rem;
        }
        .changelog-header h2 span { color: var(--accent); }
        .changelog-close {
            background: none; border: none; color: var(--text-muted);
            cursor: pointer; padding: 0.25rem; border-radius: 6px;
            transition: all 0.2s;
            display: flex; align-items: center; justify-content: center;
        }
        .changelog-close:hover { color: var(--text); background: var(--surface-2); }
        .changelog-body {
            overflow-y: auto; padding: 1.5rem;
            display: flex; flex-direction: column; gap: 1.5rem;
        }
        .changelog-entry {
            border-left: 2px solid var(--border);
            padding-left: 1rem;
            transition: border-color 0.3s;
        }
        .changelog-entry:first-child { border-left-color: var(--accent); }
        .changelog-entry-header {
            display: flex; align-items: center; gap: 0.75rem;
            margin-bottom: 0.5rem;
        }
        .changelog-entry-version {
            font-size: 0.875rem; font-weight: 700;
            color: var(--text);
            background: var(--surface-2);
            padding: 0.15rem 0.6rem;
            border-radius: 6px;
            font-family: 'JetBrains Mono', monospace;
        }
        .changelog-entry:first-child .changelog-entry-version {
            background: rgba(249,115,22,0.15);
            color: var(--accent);
        }
        .changelog-entry-date {
            font-size: 0.75rem; color: var(--text-subtle);
        }
        .changelog-section-title {
            font-size: 0.7rem; font-weight: 600;
            text-transform: uppercase; letter-spacing: 0.05em;
            color: var(--text-muted);
            margin: 0.5rem 0 0.25rem;
            display: flex; align-items: center; gap: 0.35rem;
        }
        .changelog-items {
            list-style: none; padding: 0;
            display: flex; flex-direction: column; gap: 0.2rem;
        }
        .changelog-items li {
            font-size: 0.8rem; color: var(--text-muted);
            line-height: 1.5;
            padding-left: 1rem;
            position: relative;
        }
        .changelog-items li::before {
            content: '';
            position: absolute; left: 0; top: 0.55em;
            width: 4px; height: 4px; border-radius: 50%;
            background: var(--text-subtle);
        }

        /* =========== HERO =========== */
        .hero {
            min-height: 100vh;
            display: flex; align-items: center;
            position: relative; overflow: hidden;
            padding-top: 6rem;
        }

        /* Animated mesh gradient background */
        .hero-mesh {
            position: absolute; inset: -50%; pointer-events: none;
            background:
                radial-gradient(900px circle at 25% 30%, rgba(249,115,22,0.14), transparent 55%),
                radial-gradient(700px circle at 75% 25%, rgba(168,85,247,0.1), transparent 55%),
                radial-gradient(500px circle at 55% 75%, rgba(59,130,246,0.08), transparent 50%);
            animation: gradient-shift 15s ease infinite;
            background-size: 200% 200%;
        }

        /* Dot grid */
        .hero-dots {
            position: absolute; inset: 0; pointer-events: none;
            background-image: radial-gradient(circle, var(--border) 1px, transparent 1px);
            background-size: 40px 40px;
            mask-image: radial-gradient(ellipse 70% 55% at 50% 40%, black 10%, transparent 80%);
            -webkit-mask-image: radial-gradient(ellipse 70% 55% at 50% 40%, black 10%, transparent 80%);
            opacity: 0.35;
        }

        /* Floating orbs */
        .orb {
            position: absolute;
            border-radius: 50%;
            filter: blur(80px);
            pointer-events: none;
            animation: float 8s ease-in-out infinite;
        }
        .orb-1 {
            width: 400px; height: 400px;
            background: rgba(249,115,22,0.08);
            top: 10%; left: 5%;
            animation-delay: 0s;
        }
        .orb-2 {
            width: 300px; height: 300px;
            background: rgba(168,85,247,0.06);
            top: 60%; right: 10%;
            animation-delay: -3s;
            animation-duration: 10s;
        }
        .orb-3 {
            width: 200px; height: 200px;
            background: rgba(59,130,246,0.06);
            bottom: 10%; left: 30%;
            animation-delay: -5s;
            animation-duration: 12s;
        }

        .hero .container { position: relative; z-index: 2; }
        .hero-layout {
            display: grid;
            grid-template-columns: 1fr 1.1fr;
            gap: 5rem; align-items: center;
        }

        /* Hero text animations */
        .hero-content > * {
            opacity: 0;
            animation: fadeUp 1s cubic-bezier(0.16, 1, 0.3, 1) forwards;
        }
        .hero-content > *:nth-child(1) { animation-delay: 0.1s; }
        .hero-content > *:nth-child(2) { animation-delay: 0.25s; }
        .hero-content > *:nth-child(3) { animation-delay: 0.4s; }
        .hero-content > *:nth-child(4) { animation-delay: 0.55s; }

        .hero-badge {
            display: inline-flex; align-items: center; gap: 0.625rem;
            padding: 0.4rem 1.125rem;
            background: var(--surface);
            border: 1px solid var(--border);
            border-radius: 9999px;
            font-size: 0.8rem; font-weight: 500;
            color: var(--text-muted);
            margin-bottom: 2rem;
        }
        .hero-badge .dot {
            width: 6px; height: 6px;
            border-radius: 50%;
            background: var(--green);
            animation: pulse-glow 2s ease-in-out infinite;
        }
        .hero-badge span { color: var(--accent); font-weight: 700; }

        .hero h1 {
            font-size: clamp(3rem, 5.5vw, 4.5rem);
            font-weight: 900; line-height: 1.05;
            letter-spacing: -0.04em;
            margin-bottom: 1.75rem;
        }
        .hero h1 .gradient {
            background: linear-gradient(135deg, var(--accent) 0%, #fbbf24 40%, var(--accent) 80%);
            background-size: 300% auto;
            -webkit-background-clip: text;
            -webkit-text-fill-color: transparent;
            background-clip: text;
            animation: shimmer 5s ease-in-out infinite;
        }
        .hero-sub {
            font-size: 1.2rem; color: var(--text-muted);
            margin-bottom: 2.5rem; max-width: 500px; line-height: 1.8;
        }
        .hero-actions { display: flex; gap: 1rem; flex-wrap: wrap; align-items: center; }

        .btn {
            display: inline-flex; align-items: center; gap: 0.5rem;
            padding: 0.9rem 1.8rem; border-radius: 12px;
            font-weight: 600; font-size: 0.95rem;
            text-decoration: none;
            transition: all 0.35s cubic-bezier(0.16, 1, 0.3, 1);
            border: none; cursor: pointer;
            position: relative;
            overflow: hidden;
        }
        .btn::before {
            content: '';
            position: absolute; inset: 0;
            background: linear-gradient(135deg, rgba(255,255,255,0.15), transparent);
            opacity: 0;
            transition: opacity 0.3s;
        }
        .btn:hover::before { opacity: 1; }
        .btn-primary {
            background: linear-gradient(135deg, var(--accent), #ea580c);
            color: white;
            box-shadow: 0 0 30px rgba(249,115,22,0.25), 0 0 60px rgba(249,115,22,0.1);
        }
        .btn-primary:hover {
            transform: translateY(-3px);
            box-shadow: 0 8px 40px rgba(249,115,22,0.4), 0 0 80px rgba(249,115,22,0.15);
        }
        .btn-ghost {
            background: rgba(255,255,255,0.03);
            color: var(--text);
            border: 1px solid var(--border);
            backdrop-filter: blur(8px);
        }
        .btn-ghost:hover {
            border-color: var(--text-subtle);
            background: rgba(255,255,255,0.06);
            transform: translateY(-2px);
        }

        /* Hero code window */
        .hero-code-wrap {
            opacity: 0;
            animation: slideLeft 1s cubic-bezier(0.16, 1, 0.3, 1) 0.5s forwards;
            perspective: 1200px;
        }
        .hero-code {
            background: var(--surface);
            border: 1px solid var(--border);
            border-radius: 16px;
            overflow: hidden;
            box-shadow:
                0 32px 64px -16px rgba(0,0,0,0.6),
                0 0 0 1px rgba(255,255,255,0.03) inset;
            transform: rotateY(-2deg) rotateX(1deg);
            transition: transform 0.6s cubic-bezier(0.16, 1, 0.3, 1);
        }
        .hero-code:hover {
            transform: rotateY(0deg) rotateX(0deg);
        }
        .code-titlebar {
            display: flex; align-items: center; gap: 0.5rem;
            padding: 1rem 1.25rem;
            background: rgba(255,255,255,0.02);
            border-bottom: 1px solid var(--border-muted);
        }
        .code-dot { width: 10px; height: 10px; border-radius: 50%; transition: transform 0.2s; }
        .code-dot:hover { transform: scale(1.3); }
        .code-dot.r { background: #ef4444; }
        .code-dot.y { background: #eab308; }
        .code-dot.g { background: #22c55e; }
        .code-filename {
            margin-left: 0.75rem;
            font-size: 0.75rem; color: var(--text-subtle);
            font-family: 'JetBrains Mono', monospace;
        }
        .hero-code pre {
            margin: 0; padding: 1.5rem;
            overflow-x: auto;
            font-family: 'JetBrains Mono', monospace;
            font-size: 0.78rem; line-height: 1.85;
            color: var(--text-muted);
        }
        .hero-code :global(.key) { color: #7dd3fc; }
        .hero-code :global(.str) { color: #86efac; }
        .hero-code :global(.num) { color: #fb923c; }
        .hero-code :global(.bool) { color: #c084fc; }
        .hero-code :global(.null) { color: #94a3b8; }
        .hero-code :global(.brace) { color: #6b6b78; }
        .hero-code :global(.bracket) { color: #6b6b78; }
        .hero-code :global(.tmpl) { color: var(--accent); font-weight: 500; }
        .hero-code :global(.action-name) { color: #fbbf24; }

        /* Code line highlight on hover */
        .code-line {
            display: block;
            padding: 0 0.5rem;
            margin: 0 -0.5rem;
            border-radius: 4px;
            transition: background 0.2s;
        }
        .code-line:hover {
            background: rgba(249,115,22,0.06);
        }

        /* =========== STATS =========== */
        .stats {
            padding: 5rem 0;
            position: relative;
        }
        .stats::before {
            content: '';
            position: absolute; top: 0; left: 50%; transform: translateX(-50%);
            width: 60%; height: 1px;
            background: linear-gradient(90deg, transparent, var(--border), transparent);
        }
        .stats::after {
            content: '';
            position: absolute; bottom: 0; left: 50%; transform: translateX(-50%);
            width: 60%; height: 1px;
            background: linear-gradient(90deg, transparent, var(--border), transparent);
        }
        .stats-grid {
            display: grid; grid-template-columns: repeat(4, 1fr); gap: 2rem;
            text-align: center;
        }
        .stat {
            padding: 1rem;
            position: relative;
        }
        .stat-value {
            font-size: 3rem; font-weight: 900;
            letter-spacing: -0.03em;
            background: linear-gradient(135deg, var(--accent), #fbbf24);
            -webkit-background-clip: text;
            -webkit-text-fill-color: transparent;
            background-clip: text;
            line-height: 1;
        }
        .stat.visible .stat-value {
            animation: counter-pulse 0.6s ease 0.3s;
        }
        .stat-label {
            font-size: 0.8rem; color: var(--text-subtle);
            margin-top: 0.5rem;
            text-transform: uppercase;
            letter-spacing: 0.08em;
            font-weight: 500;
        }

        /* =========== FEATURES =========== */
        .features { padding: 8rem 0; }
        .section-label {
            display: inline-flex; align-items: center; gap: 0.5rem;
            padding: 0.375rem 1rem;
            background: rgba(249,115,22,0.08);
            border: 1px solid rgba(249,115,22,0.2);
            border-radius: 9999px;
            font-size: 0.75rem; font-weight: 700;
            color: var(--accent);
            margin-bottom: 1.5rem;
            text-transform: uppercase;
            letter-spacing: 0.08em;
        }
        .section-heading {
            font-size: clamp(2.25rem, 4vw, 3.25rem);
            font-weight: 900; line-height: 1.1;
            letter-spacing: -0.03em;
            margin-bottom: 1rem;
        }
        .section-desc {
            font-size: 1.1rem; color: var(--text-muted);
            max-width: 560px; line-height: 1.7;
            margin-bottom: 4rem;
        }
        .feature-grid {
            display: grid;
            grid-template-columns: repeat(3, 1fr);
            gap: 1.25rem;
        }
        .feature-card {
            background: var(--surface);
            border: 1px solid var(--border-muted);
            border-radius: 16px;
            padding: 2rem;
            position: relative;
            overflow: hidden;
            transition: all 0.4s cubic-bezier(0.16, 1, 0.3, 1);
        }
        /* Glow on hover */
        .feature-card::before {
            content: '';
            position: absolute; top: -1px; left: -1px; right: -1px;
            height: 3px;
            background: linear-gradient(90deg, transparent, var(--card-accent, var(--accent)), transparent);
            opacity: 0;
            transition: opacity 0.4s;
        }
        .feature-card::after {
            content: '';
            position: absolute; inset: 0;
            background: radial-gradient(400px circle at var(--mx, 50%) var(--my, 0%), var(--card-glow, rgba(249,115,22,0.06)), transparent 60%);
            opacity: 0;
            transition: opacity 0.4s;
            pointer-events: none;
        }
        .feature-card:hover {
            border-color: var(--border);
            transform: translateY(-6px);
            box-shadow: 0 20px 60px -15px rgba(0,0,0,0.5);
        }
        .feature-card:hover::before { opacity: 1; }
        .feature-card:hover::after { opacity: 1; }

        .feature-icon {
            width: 3rem; height: 3rem;
            border-radius: 12px;
            display: flex; align-items: center; justify-content: center;
            margin-bottom: 1.25rem;
            font-size: 1.25rem;
            font-weight: 700;
            transition: transform 0.3s;
        }
        .feature-card:hover .feature-icon { transform: scale(1.1) rotate(-3deg); }
        .fi-orange { background: rgba(249,115,22,0.12); color: var(--accent); }
        .fi-blue { background: rgba(59,130,246,0.12); color: var(--blue); }
        .fi-green { background: rgba(34,197,94,0.12); color: var(--green); }
        .fi-purple { background: rgba(168,85,247,0.12); color: var(--purple); }
        .fi-cyan { background: rgba(6,182,212,0.12); color: var(--cyan); }
        .fi-red { background: rgba(239,68,68,0.12); color: var(--red); }
        .feature-card h3 {
            font-size: 1.1rem; font-weight: 700;
            margin-bottom: 0.5rem; letter-spacing: -0.01em;
        }
        .feature-card p {
            color: var(--text-muted); font-size: 0.875rem; line-height: 1.65;
        }

        /* =========== HOW IT WORKS =========== */
        .how-it-works {
            padding: 8rem 0;
            position: relative;
        }
        .how-it-works .center { text-align: center; }
        .how-it-works .section-desc { margin-left: auto; margin-right: auto; }
        .steps-grid {
            display: grid; grid-template-columns: repeat(3, 1fr);
            gap: 0; margin-top: 4rem;
            position: relative;
        }
        /* Connecting line */
        .steps-line {
            position: absolute;
            top: 2rem; left: 16.67%; right: 16.67%;
            height: 2px;
            background: var(--border-muted);
            z-index: 0;
        }
        .steps-line-fill {
            height: 100%; width: 0;
            background: linear-gradient(90deg, var(--accent), var(--purple), var(--blue));
            transition: width 1.5s cubic-bezier(0.16, 1, 0.3, 1);
            border-radius: 2px;
        }
        .steps-line.visible .steps-line-fill { width: 100%; }
        .step {
            text-align: center; padding: 0 2rem;
            position: relative; z-index: 1;
        }
        .step-circle {
            width: 4rem; height: 4rem;
            border-radius: 50%;
            display: flex; align-items: center; justify-content: center;
            font-size: 1.25rem; font-weight: 900;
            margin: 0 auto 1.5rem;
            position: relative;
            z-index: 2;
            transition: all 0.4s;
        }
        .step-circle::before {
            content: '';
            position: absolute; inset: -4px;
            border-radius: 50%;
            border: 2px solid transparent;
            transition: border-color 0.4s;
        }
        .step:nth-child(2) .step-circle { background: var(--bg); box-shadow: inset 0 0 0 3px rgba(249,115,22,0.3), 0 0 0 8px var(--bg); color: var(--accent); }
        .step:nth-child(2) .step-circle::before { border-color: rgba(249,115,22,0.3); }
        .step:nth-child(3) .step-circle { background: var(--bg); box-shadow: inset 0 0 0 3px rgba(168,85,247,0.3), 0 0 0 8px var(--bg); color: var(--purple); }
        .step:nth-child(3) .step-circle::before { border-color: rgba(168,85,247,0.3); }
        .step:nth-child(4) .step-circle { background: var(--bg); box-shadow: inset 0 0 0 3px rgba(59,130,246,0.3), 0 0 0 8px var(--bg); color: var(--blue); }
        .step:nth-child(4) .step-circle::before { border-color: rgba(59,130,246,0.3); }
        .step:hover .step-circle { transform: scale(1.1); }
        .step h3 {
            font-size: 1.2rem; font-weight: 700;
            margin-bottom: 0.625rem;
        }
        .step p { color: var(--text-muted); font-size: 0.9rem; line-height: 1.65; }

        /* =========== USE CASES =========== */
        .use-cases { padding: 8rem 0; }
        .use-case-grid {
            display: grid; grid-template-columns: repeat(2, 1fr);
            gap: 1.25rem; margin-top: 4rem;
        }
        .use-case {
            background: var(--surface);
            border: 1px solid var(--border-muted);
            border-radius: 16px;
            padding: 2rem;
            display: flex; gap: 1.25rem;
            transition: all 0.4s cubic-bezier(0.16, 1, 0.3, 1);
            cursor: default;
        }
        .use-case:hover {
            border-color: var(--border);
            transform: translateY(-3px) translateX(3px);
            box-shadow: -8px 8px 32px -8px rgba(0,0,0,0.3);
        }
        .use-case-icon {
            flex-shrink: 0;
            width: 2.75rem; height: 2.75rem;
            border-radius: 10px;
            display: flex; align-items: center; justify-content: center;
            font-size: 1.25rem;
            transition: transform 0.3s;
        }
        .use-case:hover .use-case-icon { transform: rotate(-8deg) scale(1.15); }
        .use-case h3 { font-size: 1rem; font-weight: 700; margin-bottom: 0.375rem; }
        .use-case p { color: var(--text-muted); font-size: 0.85rem; line-height: 1.6; }

        /* =========== TECH STACK =========== */
        .tech-stack { padding: 6rem 0; }
        .tech-stack .center { text-align: center; }
        .tech-stack .section-desc { margin-left: auto; margin-right: auto; }
        .tech-grid {
            display: flex; justify-content: center; gap: 3rem;
            flex-wrap: wrap; margin-top: 3rem;
        }
        .tech-item {
            display: flex; flex-direction: column; align-items: center;
            gap: 0.75rem; padding: 1.5rem 2rem;
            border-radius: 12px;
            transition: all 0.3s;
            cursor: default;
        }
        .tech-item:hover {
            background: var(--surface);
            transform: translateY(-4px);
        }
        .tech-icon {
            font-size: 2rem;
            width: 3.5rem; height: 3.5rem;
            display: flex; align-items: center; justify-content: center;
            border-radius: 12px;
            background: var(--surface);
            border: 1px solid var(--border-muted);
            transition: border-color 0.3s;
        }
        .tech-icon svg {
            width: 2rem; height: 2rem;
            fill: currentColor;
        }
        .tech-icon img {
            width: 2rem; height: 2rem;
            object-fit: contain;
        }
        .tech-item:hover .tech-icon { border-color: var(--accent); }
        .tech-name { font-size: 0.8rem; color: var(--text-muted); font-weight: 600; }

        /* =========== CTA =========== */
        .cta {
            padding: 10rem 0; text-align: center;
            position: relative; overflow: hidden;
        }
        .cta-glow {
            position: absolute; inset: 0; pointer-events: none;
            background: radial-gradient(600px circle at 50% 60%, rgba(249,115,22,0.1), transparent 60%);
        }
        .cta-ring {
            position: absolute;
            top: 50%; left: 50%; transform: translate(-50%, -50%);
            width: 600px; height: 600px;
            border-radius: 50%;
            border: 1px solid rgba(249,115,22,0.08);
            pointer-events: none;
            animation: pulse-glow 4s ease-in-out infinite;
        }
        .cta-ring:nth-child(2) {
            width: 800px; height: 800px;
            animation-delay: -1s;
        }
        .cta .container { position: relative; z-index: 1; }
        .cta h2 {
            font-size: clamp(2.25rem, 4.5vw, 3.5rem);
            font-weight: 900; margin-bottom: 1rem;
            letter-spacing: -0.03em;
        }
        .cta p {
            font-size: 1.15rem; color: var(--text-muted);
            margin-bottom: 3rem;
            max-width: 480px; margin-left: auto; margin-right: auto;
        }
        .cta .hero-actions { justify-content: center; }

        /* =========== FOOTER =========== */
        footer {
            padding: 3rem 0;
            border-top: 1px solid var(--border-muted);
        }
        footer .container {
            display: flex; align-items: center; justify-content: space-between;
        }
        .footer-copy { color: var(--text-subtle); font-size: 0.8rem; }
        .footer-links { display: flex; gap: 2rem; }
        .footer-links a {
            color: var(--text-subtle); text-decoration: none;
            font-size: 0.8rem;
            transition: color 0.3s;
        }
        .footer-links a:hover { color: var(--accent); }

        /* =========== RESPONSIVE =========== */
        @media (max-width: 1024px) {
            .hero-layout { grid-template-columns: 1fr; gap: 3rem; }
            .feature-grid { grid-template-columns: repeat(2, 1fr); }
        }
        @media (max-width: 768px) {
            .stats-grid { grid-template-columns: repeat(2, 1fr); gap: 1.5rem; }
            .feature-grid { grid-template-columns: 1fr; }
            .steps-grid { grid-template-columns: 1fr; gap: 2rem; }
            .steps-line { display: none; }
            .use-case-grid { grid-template-columns: 1fr; }
            .nav-links { display: none; }
            footer .container { flex-direction: column; gap: 1rem; text-align: center; }
            .footer-links { justify-content: center; }
            .hero h1 { font-size: 2.5rem; }
        }
    </style>
