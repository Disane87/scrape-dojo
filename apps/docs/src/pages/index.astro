<!-- Stats -->
<section class="stats">
    <div class="container">
        <div class="stats-grid">
            <div class="stat reveal" style="--i:0">
                <div class="stat-value" data-target="25" data-suffix="+">0</div>
                <div class="stat-label">Built-in Actions</div>
            </div>
            <div class="stat reveal" style="--i:1">
                <div class="stat-value" data-target="4">0</div>
                <div class="stat-label">Trigger Types</div>
            </div>
            <div class="stat reveal" style="--i:2">
                <div class="stat-value" data-target="3">0</div>
                <div class="stat-label">Database Backends</div>
            </div>
            <div class="stat reveal" style="--i:3">
                <div class="stat-value" data-text="SSE">---</div>
                <div class="stat-label">Real-time Events</div>
            </div>
        </div>
    </div>
</section>

<!-- Features -->
<section class="features">
    <div class="container">
        <div class="reveal"><div class="section-label">Features</div></div>
        <h2 class="section-heading reveal">Alles was du brauchst.</h2>
        <p class="section-desc reveal">
            Von der einfachen Datenextraktion bis zum komplexen Multi-Step-Workflow
            mit Login, OTP und Datei-Downloads.
        </p>
        <div class="feature-grid stagger">
            <div class="feature-card reveal" style="--i:0; --card-accent: var(--accent); --card-glow: rgba(249,115,22,0.06);">
                <div class="feature-icon fi-orange">{ }</div>
                <h3>JSONC Konfiguration</h3>
                <p>Deklarative Workflows in JSON mit Kommentaren. Schema-Validierung, Hot Reload im Dev-Modus, kein Code noetig.</p>
            </div>
            <div class="feature-card reveal" style="--i:1; --card-accent: var(--blue); --card-glow: rgba(59,130,246,0.06);">
                <div class="feature-icon fi-blue">&lt;/&gt;</div>
                <h3>Handlebars + JSONata</h3>
                <p>Dynamische Templates fuer String-Interpolation und machtvolle JSONata-Ausdruecke fuer Datentransformationen.</p>
            </div>
            <div class="feature-card reveal" style="--i:2; --card-accent: var(--green); --card-glow: rgba(34,197,94,0.06);">
                <div class="feature-icon fi-green">25+</div>
                <h3>Action Library</h3>
                <p>Navigation, Klicks, Eingaben, Extraktion, Loops, Bedingungen, Downloads, Screenshots und Benachrichtigungen.</p>
            </div>
            <div class="feature-card reveal" style="--i:3; --card-accent: var(--purple); --card-glow: rgba(168,85,247,0.06);">
                <div class="feature-icon fi-purple">&#9201;</div>
                <h3>Cron-Scheduling</h3>
                <p>Automatische Ausfuehrung per Cron mit Timezone-Support. Plus Webhook- und Startup-Triggers.</p>
            </div>
            <div class="feature-card reveal" style="--i:4; --card-accent: var(--cyan); --card-glow: rgba(6,182,212,0.06);">
                <div class="feature-icon fi-cyan">&#9737;</div>
                <h3>Live-Monitoring</h3>
                <p>Server-Sent Events streamen jeden Action-Status in Echtzeit an die Angular 21 UI mit Run-History und Debug-Daten.</p>
            </div>
            <div class="feature-card reveal" style="--i:5; --card-accent: var(--red); --card-glow: rgba(239,68,68,0.06);">
                <div class="feature-icon fi-red">&#9919;</div>
                <h3>Security &amp; Auth</h3>
                <p>AES-256-CBC Secrets, JWT + Refresh Tokens, OIDC/SSO, MFA/TOTP, API Keys. Auth optional deaktivierbar.</p>
            </div>
        </div>
    </div>
</section>

<!-- How it works -->
<section class="how-it-works">
    <div class="container center">
        <div class="reveal"><div class="section-label">Workflow</div></div>
        <h2 class="section-heading reveal">Drei Schritte, fertig.</h2>
        <p class="section-desc reveal">
            Kein Boilerplate, kein Puppeteer-Setup, kein Browser-Management.
        </p>
        <div class="steps-grid">
            <div class="steps-line" id="steps-line"><div class="steps-line-fill"></div></div>
            <div class="step reveal" style="--i:0">
                <div class="step-circle">1</div>
                <h3>Konfigurieren</h3>
                <p>Erstelle eine JSONC-Datei in config/sites/ mit deinen Steps und Actions. Schema-Validierung hilft dir dabei.</p>
            </div>
            <div class="step reveal" style="--i:1">
                <div class="step-circle">2</div>
                <h3>Ausfuehren</h3>
                <p>Starte per UI-Klick, API-Call, Cron-Schedule oder Webhook. Variablen und Secrets werden automatisch aufgeloest.</p>
            </div>
            <div class="step reveal" style="--i:2">
                <div class="step-circle">3</div>
                <h3>Ueberwachen</h3>
                <p>Verfolge die Ausfuehrung live per SSE. Debug-Daten, Artefakte und Run-History stehen sofort bereit.</p>
            </div>
        </div>
    </div>
</section>

<!-- Use Cases -->
<section class="use-cases">
    <div class="container">
        <div class="reveal"><div class="section-label">Use Cases</div></div>
        <h2 class="section-heading reveal">Was du damit machen kannst.</h2>
        <div class="use-case-grid stagger">
            <div class="use-case reveal" style="--i:0">
                <div class="use-case-icon fi-orange">&#128196;</div>
                <div>
                    <h3>Rechnungen herunterladen</h3>
                    <p>Automatisch PDFs von Portalen sammeln, Duplikate per fileExists erkennen, mit Scheduling monatlich ausfuehren.</p>
                </div>
            </div>
            <div class="use-case reveal" style="--i:1">
                <div class="use-case-icon fi-blue">&#128200;</div>
                <div>
                    <h3>Preise ueberwachen</h3>
                    <p>Produktdaten extrahieren, mit JSONata transformieren, als strukturierte Daten speichern und vergleichen.</p>
                </div>
            </div>
            <div class="use-case reveal" style="--i:2">
                <div class="use-case-icon fi-green">&#128274;</div>
                <div>
                    <h3>Login-Flows automatisieren</h3>
