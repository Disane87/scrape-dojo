{
  "name": "@disane87/scrape-dojo",
  "description": "Define your scrapes with JSON configurations, use dynamic templates, and automate web tasks!",
  "homepage": "https://github.com/disane87/scrape-dojo#readme",
  "license": "MIT",
  "author": {
    "name": "Marco Franke",
    "url": "https://github.com/disane87",
    "email": "mfranke87@icloud.com"
  },
  "repository": {
    "url": "https://github.com/disane87/scrape-dojo.git"
  },
  "scripts": {
    "build": "nx run-many -t build",
    "build:api": "nx build api",
    "build:ui": "nx build ui",
    "build:docs": "nx build docs",
    "format": "nx format:write",
    "format:check": "nx format:check",
    "start": "nx run-many -t serve",
    "start:api": "nx serve api",
    "start:ui": "nx serve ui",
    "start:api:debug": "nx serve api --configuration=development -- --inspect",
    "start:prod": "node dist/apps/api/main.js",
    "start:docs": "nx serve docs",
    "lint": "nx run-many -t lint",
    "lint:fix": "nx run-many -t lint -- --fix",
    "test": "nx run-many -t test",
    "test:api": "nx test api",
    "test:ui": "nx test ui",
    "test:watch": "nx test api --watch",
    "test:cov": "nx test api --coverage",
    "test:e2e": "vitest run --config ./test/vitest.config.e2e.ts",
    "test:all": "nx run-many -t test && nx e2e api-e2e",
    "test:api:watch": "nx test api --watch",
    "test:ui:watch": "nx test ui --watch",
    "test:coverage": "nx run-many -t test --coverage",
    "test:server": "npx servor test/files index.html 8080 --reload --browse",
    "create:schema": "npx typescript-json-schema tsconfig.json Scrapes --out config/scrapes.schema.json",
    "generate:types": "node ./scripts/create-action-type.js",
    "generate:openapi": "powershell -ExecutionPolicy Bypass -File ./scripts/generate-openapi.ps1",
    "docs:openapi": "pnpm generate:openapi && cd apps/docs && pnpm docusaurus clean-api-docs all && pnpm docusaurus gen-api-docs all",
    "update:version": "node ./scripts/update-version.js",
    "prebuild": "pnpm update:version",
    "graph": "nx graph",
    "affected": "nx affected",
    "affected:build": "nx affected -t build",
    "affected:test": "nx affected -t test",
    "affected:lint": "nx affected -t lint",
    "release": "semantic-release",
    "prepare": "husky"
  },
