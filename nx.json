{
  "$schema": "./node_modules/nx/schemas/nx-schema.json",
  "nxCloudId": "69493b1616e7bd2408cfa991",
  "neverConnectToCloud": true,
  "targetDefaults": {
    "@angular/build:application": {
      "cache": true,
      "dependsOn": [
        "^build"
      ],
      "inputs": [
        "default",
        "^default"
      ]
    }
  },
  "generators": {
    "@nx/angular:application": {
      "e2eTestRunner": "none",
      "linter": "eslint",
      "style": "scss",
      "unitTestRunner": "none"
    }
  }
}