{
    "$schema": "http://json-schema.org/draft-07/schema#",
    "definitions": {
        "ActionName": {
            "enum": [
                "extract",
                "extractAll",
                "wait"
            ],
            "type": "string"
        },
        "Scrape": {
            "properties": {
                "id": {
                    "type": "string"
                },
                "steps": {
                    "items": {
                        "$ref": "#/definitions/ScrapeStep"
                    },
                    "type": "array"
                },
                "url": {
                    "type": "string"
                }
            },
